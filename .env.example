# ── Wallet Infrastructure ────────────────────────────────────────────
# Platform-level credentials — set once, works for all users
PRIVY_APP_ID=your_privy_app_id
PRIVY_APP_SECRET=your_privy_app_secret

# ── Trade Execution ──────────────────────────────────────────────────
# 0x Protocol API key — get free key at https://0x.org/docs/introduction/getting-started
ZERO_X_API_KEY=your_0x_api_key

# ── Market Data ──────────────────────────────────────────────────────
# Optional: CoinGecko Pro key for higher rate limits
# Free tier works without a key
COINGECKO_API_KEY=

# ── Network ──────────────────────────────────────────────────────────
# Base mainnet RPC (default works without setting this)
BASE_RPC_URL=https://mainnet.base.org